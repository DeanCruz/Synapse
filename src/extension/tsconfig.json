{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "rootDir": ".",
    "outDir": "../../dist/extension",
    "types": ["node", "vscode"],
    "lib": ["ES2020"],
    "sourceMap": true,
    "inlineSources": true,
    "declaration": false,
    "noEmitOnError": true,
    "strict": false,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["extension.ts", "commands/**/*.ts", "services/**/*.ts", "webview/**/*.ts", "views/**/*.ts"]
}
