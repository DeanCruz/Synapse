{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/enforce-dashboard-isolation.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/validate-master-write.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/validate-initialization-immutable.sh"
          }
        ]
      },
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/validate-worker-prompt.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/enforce-dashboard-isolation-bash.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/validate-archive-before-clear.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/validate-progress-file.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/validate-progress-log-detail.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/mark-annotation-stale.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/validate-log-entry.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/validate-master-state.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/nudge-progress-update.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/verify-final-report.sh"
          }
        ]
      }
    ]
  }
}
