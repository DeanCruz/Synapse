{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/enforce-dashboard-isolation.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/enforce-instance-type.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/enforce-tracker-root-writes.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/validate-master-write.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/validate-plan-required.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/validate-initialization-immutable.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/validate-initialization-schema.sh"
          }
        ]
      },
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/validate-worker-prompt.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/validate-approval-gate.sh"
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/validate-wave-lifecycle.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/enforce-dashboard-isolation-bash.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/enforce-tracker-root-writes-bash.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/validate-archive-before-clear.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/enforce-command-compliance.sh"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/validate-progress-file.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/validate-progress-log-detail.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/mark-annotation-stale.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/validate-log-entry.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/validate-master-state.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/validate-chat-dashboard.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/nudge-progress-update.sh"
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/worker-status-on-dispatch.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/worker-status-on-notify.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/verify-final-report.sh"
          }
        ]
      }
    ]
  }
}
