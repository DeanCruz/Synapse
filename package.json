{
  "name": "synapse",
  "version": "1.0.0",
  "description": "Synapse is a distributed control system for coordinating autonomous agent swarms. It optimizes context usage, parallelizes execution, and provides a centralized control plane for complex software development tasks.",
  "main": "electron/main.js",
  "scripts": {
    "build": "vite build",
    "start": "vite build && unset ELECTRON_RUN_AS_NODE && electron .",
    "dev": "concurrently -k \"vite\" \"electron .\"",
    "dist": "vite build && electron-builder --mac",
    "postinstall": "electron-rebuild -f -w node-pty"
  },
  "build": {
    "appId": "com.synapse.app",
    "productName": "Synapse",
    "mac": {
      "icon": "electron/assets/icon.icns",
      "target": "dmg",
      "category": "public.app-category.developer-tools"
    },
    "files": [
      "electron/**/*",
      "src/server/**/*",
      "dist/**/*",
      "!node_modules/**/*"
    ],
    "asarUnpack": [
      "node_modules/node-pty/**"
    ],
    "extraResources": [
      {
        "from": "electron/assets/icon.icns",
        "to": "icon.icns"
      },
      {
        "from": "agent",
        "to": "synapse/agent",
        "filter": ["**/*"]
      },
      {
        "from": "documentation",
        "to": "synapse/documentation",
        "filter": ["**/*"]
      },
      {
        "from": "CLAUDE.md",
        "to": "synapse/CLAUDE.md"
      },
      {
        "from": "dashboards",
        "to": "synapse/dashboards",
        "filter": ["**/*"]
      },
      {
        "from": "_commands",
        "to": "synapse/_commands",
        "filter": ["**/*"]
      },
      {
        "from": "tasks",
        "to": "synapse/tasks",
        "filter": ["**/*"]
      },
      {
        "from": "Archive",
        "to": "synapse/Archive",
        "filter": ["**/*"]
      },
      {
        "from": "queue",
        "to": "synapse/queue",
        "filter": ["**/*"]
      },
      {
        "from": "history",
        "to": "synapse/history",
        "filter": ["**/*"]
      },
      {
        "from": "conversations",
        "to": "synapse/conversations",
        "filter": ["**/*"]
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "YourGitHubOwner",
      "repo": "Synapse"
    }
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "vite": "^8.0.0"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "electron-updater": "^6.3.9",
    "monaco-editor": "^0.55.1",
    "node-pty": "^1.1.0",
    "nvm": "^0.0.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
