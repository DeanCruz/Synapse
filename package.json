{
  "name": "synapse",
  "version": "1.0.0",
  "description": "Synapse is a distributed control system for coordinating autonomous agent swarms. It optimizes context usage, parallelizes execution, and provides a centralized control plane for complex software development tasks.",
  "main": "electron/main.js",
  "scripts": {
    "start": "unset ELECTRON_RUN_AS_NODE && electron .",
    "server": "node src/server/index.js",
    "dist": "electron-builder --mac"
  },
  "build": {
    "appId": "com.synapse.app",
    "productName": "Synapse",
    "mac": {
      "target": "dmg",
      "category": "public.app-category.developer-tools"
    },
    "files": [
      "electron/**/*",
      "src/**/*",
      "public/**/*",
      "dashboards/**/*",
      "!node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "dashboards",
        "to": "dashboards"
      }
    ]
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8"
  }
}
